APP_ENV=local
HTTP_ADDR=:8080
RUN_MIGRATIONS=true
MIGRATIONS_DIR=./migrations

POSTGRES_IMAGE=docker.m.daocloud.io/pgvector/pgvector:pg16
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7.2-alpine
POSTGRES_DSN=postgres://feishu_kb:feishu_kb_password@localhost:5432/feishu_kb?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_EVENT_MODE=websocket
FEISHU_OAUTH_REDIRECT_URI=http://localhost:8081/api/auth/feishu/callback
FEISHU_P2P_POLL_ENABLED=true
FEISHU_P2P_POLL_INTERVAL=60s
FEISHU_P2P_POLL_LOOKBACK=2m
FEISHU_TOKEN_REFRESH_ENABLED=true
FEISHU_TOKEN_REFRESH_INTERVAL=10m
FEISHU_TOKEN_REFRESH_BEFORE=30m
FEISHU_HOURLY_SYNC_ENABLED=true
FEISHU_HOURLY_SYNC_INTERVAL=1h
FEISHU_HOURLY_SYNC_DAYS=2

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_WIRE_API=responses
OPENAI_WEB_SEARCH_ENABLED=true
OPENAI_WEB_SEARCH_TOOL=web_search

OPENAI_ENABLE_EMBEDDINGS=false
OPENAI_EMBEDDING_BASE_URL=
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

VISION_ENABLED=true
VISION_BASE_URL=
VISION_API_KEY=
VISION_MODEL=
VISION_MAX_IMAGE_BYTES=10485760

DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
